{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    { "src": "/", "dest": "/index.html" },
    { "src": "/visual", "dest": "/visual.html" },
    { "src": "/presentasi", "dest": "/visual.html" },
    { "src": "/investor", "dest": "/visual.html" },
    { "src": "/form", "dest": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    }
  ]
}
